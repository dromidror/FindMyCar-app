<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A"
    android:gravity="center"
    android:padding="32dp">

    <!-- Illustration emoji (placeholder for real illustration) -->
    <TextView
        android:id="@+id/onboardingEmoji"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📍"
        android:textSize="80sp"
        android:layout_marginBottom="32dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/onboardingTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="We need your location"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/onboardingMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="To remember where your car is parked, we need access to your location.\n\nDon't worry — we only use it to save your parking spot."
        android:textSize="16sp"
        android:textColor="#AAAAAA"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginBottom="48dp" />

    <!-- Continue button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/onboardingNextButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Continue"
        android:textSize="18sp"
        app:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        app:cornerRadius="28dp"
        style="@style/Widget.Material3.Button" />

</LinearLayout>
