<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#1A1A1A">

    <!-- Debug toggle (top-right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/debugToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Debug"
            android:textColor="#666666"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- State display -->
    <TextView
        android:id="@+id/stateText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏳ Waiting for drive..."
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#AAAAAA"
        android:gravity="center" />

    <TextView
        android:id="@+id/parkInfoText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="16sp"
        android:textColor="#888888"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <!-- Big circular Find button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/findButton"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:text="FIND\nMY CAR"
        android:textSize="18sp"
        android:layout_marginTop="32dp"
        android:visibility="gone"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:backgroundTint="#2196F3"
        app:cornerRadius="80dp"
        android:textColor="#FFFFFF"
        style="@style/Widget.Material3.Button" />

    <!-- Spacer -->
    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Debug section (hidden by default) -->
    <LinearLayout
        android:id="@+id/debugSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- Debug indicators -->
        <TextView
            android:id="@+id/debugIndicators"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="12dp" />

        <!-- Debug buttons row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/testLogButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log"
                android:textSize="12sp"
                app:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/carExitButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Car Exit"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                app:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearLogsButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clear"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
