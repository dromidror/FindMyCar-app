<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- App Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Find My Car"
        android:textSize="18sp"
        android:textColor="@color/text_title"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="12dp" />

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- "Not Parked" state -->
        <LinearLayout
            android:id="@+id/notParkedView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/notParkedEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗"
                android:textSize="64sp" />

            <TextView
                android:id="@+id/notParkedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Parked"
                android:textSize="24sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/stateInfoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="8dp" />

        </LinearLayout>

        <!-- Navigation state (parked — showing direction to car) -->
        <LinearLayout
            android:id="@+id/navView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="gone">

            <!-- Floor info -->
            <TextView
                android:id="@+id/floorText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- Arrow pointing to car -->
            <ImageView
                android:id="@+id/navArrow"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:src="@drawable/ic_nav_arrow"
                android:contentDescription="Direction to car" />

            <!-- Distance -->
            <TextView
                android:id="@+id/navDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--m"
                android:textSize="48sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="16dp" />

            <!-- Accuracy / status -->
            <TextView
                android:id="@+id/navAccuracy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="8dp" />

            <!-- Status (You're here!) -->
            <TextView
                android:id="@+id/navStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="24sp"
                android:textColor="@color/success"
                android:fontFamily="sans-serif"
                android:layout_marginTop="16dp"
                android:visibility="gone" />

            <!-- Parking time info -->
            <TextView
                android:id="@+id/parkInfoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="16dp"
                android:gravity="center" />

        </LinearLayout>

    </FrameLayout>

    <!-- Missing permissions (shown when user denied any) -->
    <LinearLayout
        android:id="@+id/missingPermissionsView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/permLocationFine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ We need your location to save your parking spot"
            android:textSize="13sp"
            android:textColor="@color/warning"
            android:fontFamily="sans-serif"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/permSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Step counter needed to detect when you leave the car"
            android:textSize="13sp"
            android:textColor="@color/warning"
            android:fontFamily="sans-serif"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/permLocationBg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Location access all the time is needed to track parking"
            android:textSize="13sp"
            android:textColor="@color/warning"
            android:fontFamily="sans-serif"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/permBattery"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Allow background activity to ensure parking is recorded"
            android:textSize="13sp"
            android:textColor="@color/warning"
            android:fontFamily="sans-serif"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom Navigation Bar (hidden in PROD) -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="8dp"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

    <!-- Version -->
    <TextView
        android:id="@+id/versionText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="10sp"
        android:textColor="@color/text_version"
        android:fontFamily="sans-serif"
        android:gravity="center"
        android:paddingBottom="4dp" />

</LinearLayout>
