<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A1A">

    <!-- Main content area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Recent parking list (selectable) -->
        <TextView
            android:id="@+id/navListTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select parking location:"
            android:textColor="#888888"
            android:textSize="13sp"
            android:visibility="gone" />

        <ListView
            android:id="@+id/parkingListView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxHeight="120dp"
            android:choiceMode="singleChoice"
            android:visibility="gone"
            android:layout_marginBottom="8dp" />

        <!-- Arrow pointing to car -->
        <ImageView
            android:id="@+id/navArrow"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:src="@drawable/ic_nav_arrow"
            android:contentDescription="Direction to car" />

        <!-- Distance -->
        <TextView
            android:id="@+id/navDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--m"
            android:textSize="48sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="16dp" />

        <!-- Accuracy -->
        <TextView
            android:id="@+id/navAccuracy"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp" />

        <!-- Status (You're here!) -->
        <TextView
            android:id="@+id/navStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="24sp"
            android:textColor="#4CAF50"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Bottom button (always visible) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/foundItButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Found It! — Dismiss"
        android:textSize="18sp"
        android:layout_margin="24dp"
        app:backgroundTint="#4CAF50"
        android:textColor="#FFFFFF"
        style="@style/Widget.Material3.Button" />

</LinearLayout>
