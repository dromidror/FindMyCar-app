<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A1A"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Debug"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <!-- Indicators -->
        <TextView
            android:id="@+id/debugIndicators"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="16dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/testLogButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Start Log"
                android:textSize="13sp"
                app:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                style="@style/Widget.Material3.Button" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/carExitButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Car Exit"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                app:backgroundTint="#9C27B0"
                android:textColor="#FFFFFF"
                style="@style/Widget.Material3.Button" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/clearLogsButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Clear Logs"
                android:textSize="13sp"
                style="@style/Widget.Material3.Button.TextButton" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/resetStateButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset State"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <!-- State Machine Log -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="State Machine"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <!-- Table header -->
        <TextView
            android:id="@+id/smLogHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STATE      SRC    CNT    MOTION        PICKUP  TIME   → NEW"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="#888888"
            android:background="#222222"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <ScrollView
                android:id="@+id/smLogScrollView"
                android:layout_width="wrap_content"
                android:layout_height="300dp"
                android:background="#111111"
                android:padding="4dp">

                <TextView
                    android:id="@+id/smLogText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:textColor="#00FF00"
                    android:lineSpacingExtra="2dp" />
            </ScrollView>
        </HorizontalScrollView>

    </LinearLayout>
</ScrollView>
